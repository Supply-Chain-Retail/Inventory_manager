# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if lock file is irrelevant, ignore it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be either ignored or included, see:
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be either ignored or included, see:
#   https://pdm-project.org/latest/usage/project/#commit-the-lock-file-to-version-control
#pdm.lock

